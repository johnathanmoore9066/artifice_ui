        color 0.25s ease;
    }
    .skin-btn[aria-pressed='true'] {
      background: var(--st-accent);
      color: var(--st-btn-ink);
    }

    /* ---------- section frames ---------- */
    .stage-sec {
      max-width: 1120px;
      margin-inline: auto;
      padding: clamp(5rem, 12vh, 8rem) 6vw 3rem;
    }
    .sig-sec {
      max-width: 1120px;
      margin-inline: auto;
      padding: clamp(2.5rem, 7vh, 4.5rem) 6vw;
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: clamp(1.5rem, 5vw, 4rem);
      align-items: center;
    }
    .sig-sec.reverse .sig {
      order: 2;
    }

    /* ---------- the reusable skeleton (stage + sig share it) ---------- */
    .stage,
    .sig {
      position: relative;
      overflow: hidden;
      background: var(--st-panel);
      color: var(--st-ink);
      font-family: var(--st-body);
      border: var(--st-bw) solid var(--st-line);
      border-radius: var(--st-radius);
      box-shadow: var(--st-shadow);
      transition:
        background-color 0.55s ease,
        color 0.55s ease,
        border-color 0.55s ease,
        border-radius 0.55s ease,
        box-shadow 0.55s ease;
    }
    .stage-inner,
    .sig-stage {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.1rem;
      padding: clamp(1.8rem, 5vw, 3.2rem);
    }
    .stage-inner {
      min-height: 62vh;
      justify-content: center;
    }

    .s-tag {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--st-accent);
      border: 1px solid var(--st-line);
      border-radius: 999px;
      padding: 0.3rem 0.7rem;
    }
    [data-skin='brutalist'] .s-tag {
      border-radius: 0;
      background: #000;
      color: #fff;
    }
    .s-title {
      font-family: var(--st-head);
      font-weight: 600;
      font-size: clamp(2.2rem, 6vw, 4.4rem);
      line-height: 1.02;
      letter-spacing: -0.01em;
      white-space: pre-line;
    }
    [data-skin='brutalist'] .s-title,
    [data-skin='web3'] .s-title,
    [data-skin='retro'] .s-title {
      text-transform: uppercase;
      letter-spacing: 0.01em;
    }
    [data-skin='web3'] .s-title {
      text-shadow: 0 0 22px color-mix(in srgb, var(--st-accent) 70%, transparent);
    }
    .s-sub {
      font-family: var(--st-body);
      font-size: 1.1rem;
      line-height: 1.5;
      color: var(--st-muted);
      max-width: 46ch;
    }
    .sig-line {
      font-family: var(--st-body);
      color: var(--st-muted);
    }

    .s-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 1rem;
    }
    .s-btn {
      font-family: var(--st-head);
      font-size: 1rem;
      padding: 0.85rem 1.5rem;
      border: var(--st-bw) solid transparent;
      border-radius: var(--st-radius);
      background: var(--st-accent);
      color: var(--st-btn-ink);
      cursor: pointer;
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease,
        background 0.3s ease;
    }
    .s-link {
      font-family: var(--st-body);
      color: var(--st-muted);
      text-decoration: none;
    }

    /* per-skin button + link personalities */
    [data-skin='playful'] .s-btn:hover,
    [data-skin='playful'] .s-card:hover {
      animation: wobble 0.5s ease;
    }
    [data-skin='brutalist'] .s-btn {
      border-color: #000;
      box-shadow: 5px 5px 0 #000;
      transition: none;
      text-transform: uppercase;
    }
    [data-skin='brutalist'] .s-btn:hover {
      transform: translate(-2px, -2px);
      box-shadow: 8px 8px 0 #000;
    }
    [data-skin='brutalist'] .s-link {
      color: #1a1aff;
      text-decoration: underline;
    }
    [data-skin='web3'] .s-btn,
    .s-btn.glow {
      box-shadow:
        0 0 20px var(--st-accent),
        inset 0 0 14px color-mix(in srgb, var(--st-accent) 35%, transparent);
      animation: glowpulse 2.2s ease-in-out infinite;
    }
    [data-skin='web3'] .s-link {
      color: var(--st-accent);
    }
    [data-skin='retro'] .s-btn {
      background: linear-gradient(#fff, #b8c0d6 46%, #7c85a0 54%, #eef2ff);
      color: #10113a;
      border-color: #fff;
      text-transform: uppercase;
    }

    /* ---------- skeleton cards ---------- */
    .s-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.8rem;
      width: 100%;
    }
    .s-card {
      display: grid;
      place-items: center;
      text-align: center;
      padding: 1.3rem 0.6rem;
      font-family: var(--st-head);
      font-size: 1rem;
      background: color-mix(in srgb, var(--st-accent) 9%, var(--st-panel));
      color: var(--st-ink);
      border: var(--st-bw) solid var(--st-line);
      border-radius: calc(var(--st-radius) * 0.7);
      transition:
        transform 0.2s ease,
        background 0.3s ease;
    }
    [data-skin='web3'] .s-card {
      background: color-mix(in srgb, var(--st-accent) 8%, transparent);
      backdrop-filter: blur(3px);
    }

    /* ---------- stage foot (marquee + counter, retro only) ---------- */
    .stage-foot {
      position: relative;
      z-index: 2;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.6rem 1rem;
      padding: 0 clamp(1.8rem, 5vw, 3.2rem) clamp(1.8rem, 5vw, 3.2rem);
    }
    .s-foot {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--st-muted);
    }
    /* Retro-only stage elements hide via visibility (NOT display) so the
       stage's height is identical under every skin — the scroll-synced skin
       swaps must never shift the page under the reader. */
    .s-counter {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--st-muted);
      display: inline-block;
      visibility: hidden;
    }
    .s-counter span {
      font-variant-numeric: tabular-nums;
      letter-spacing: 0.12em;
      background: #05060d;
      color: #4be08a;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
    }
    [data-skin='retro'] .s-counter {
      visibility: visible;
    }

    /* ---------- signature copy columns ---------- */
    .sig-copy h2 {
      font-family: var(--font-quiet);
      font-size: clamp(1.7rem, 3.6vw, 2.5rem);
      margin-bottom: 0.7rem;
    }
    .sig-copy > p {
      /* --st-muted, not the cream-site --ink-soft: this column sits OUTSIDE
         the locked panel, so it must read against the page-level skin — which
         the scroll-sync keeps matched to the section being read. */
      color: var(--st-muted);
      font-size: 1.05rem;
      max-width: 44ch;
      margin-bottom: 1.4rem;
    }
    .sig-copy :global(.spec-tag) {
      margin-top: 0;
    }
    .sig-h {
      font-size: clamp(1.8rem, 5vw, 3rem);
    }
    .sig-stage {
      min-height: 46vh;
      justify-content: center;
    }

    /* ============================================================
       SIGNATURE EFFECTS — each shows only under its own skin.
       ============================================================ */
    .fx {
      position: absolute;
      inset: 0;
      display: none;
      overflow: hidden;
      pointer-events: none;
    }
    [data-skin='playful'] .fx-blobs,
    [data-skin='web3'] .fx-blobs,
    [data-skin='web3'] .fx-tron,
    [data-skin='web3'] .fx-particles,
    [data-skin='retro'] .fx-scan {
      display: block;
    }

    /* morphing blobs (playful = candy, web3 = aurora) */
    .fx-blobs span {
      position: absolute;
      width: 42%;
      aspect-ratio: 1;
      filter: blur(56px);
      opacity: 0.55;
      border-radius: 42% 58% 63% 37% / 41% 44% 56% 59%;
      animation: morph 13s ease-in-out infinite alternate;
    }
    .fx-blobs span:nth-child(1) {
      top: -8%;
      left: -6%;
      background: var(--st-accent);
    }
    .fx-blobs span:nth-child(2) {
      bottom: -12%;
      right: -8%;
      background: var(--st-accent2);
      animation-delay: -4s;
    }
    .fx-blobs span:nth-child(3) {
      top: 30%;
      left: 40%;
      background: color-mix(in srgb, var(--st-accent) 50%, var(--st-accent2));
      animation-delay: -8s;
    }
    [data-skin='web3'] .fx-blobs span {
      opacity: 0.4;
      filter: blur(70px);
    }

    /* tron grid floor (web3) */
    .fx-tron {
      top: auto;
      height: 52%;
      background-image:
        linear-gradient(to right, var(--st-accent) 1px, transparent 1px),
        linear-gradient(to bottom, var(--st-accent) 1px, transparent 1px);
      background-size: 42px 42px;
      transform: perspective(340px) rotateX(74deg);
      transform-origin: bottom center;
      opacity: 0.26;
      -webkit-mask-image: linear-gradient(to top, #000 8%, transparent 82%);
      mask-image: linear-gradient(to top, #000 8%, transparent 82%);
      animation: tron 5.5s linear infinite;
    }

    /* rising particles (web3) */
    .fx-particles span {
      position: absolute;
      bottom: -12px;
      border-radius: 50%;
      background: var(--st-accent);
      box-shadow: 0 0 8px var(--st-accent);
      animation-name: rise;
      animation-timing-function: linear;
      animation-iteration-count: infinite;
    }

    /* CRT scanlines + flicker (retro) */
    .fx-scan {
      background: repeating-linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.32) 0 1px,
        transparent 1px 3px
      );
      animation: flicker 4s steps(2) infinite;
    }
    .fx-scan::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(
        ellipse at center,
        transparent 55%,
        rgba(0, 0, 0, 0.35) 100%
      );
    }

    /* chrome gradient text (retro) */
    .chrome {
      background: linear-gradient(
        #ffffff 0%,
        #c8d0e4 42%,
        #6b7490 52%,
        #aeb8d4 60%,
        #ffffff 100%
      );
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 2px 0 rgba(0, 0, 0, 0.25);
    }

    /* glitch text (web3) */
    .glitch {
      position: relative;
    }
    .glitch::before,
    .glitch::after {
      content: attr(data-text);
      position: absolute;
      inset: 0;
      background: var(--st-panel);
    }
    .glitch::before {
      color: var(--st-accent);
      clip-path: inset(0 0 62% 0);
      animation: glitch-a 2.4s infinite linear alternate;
    }
    .glitch::after {
      color: var(--st-accent2);
      clip-path: inset(58% 0 0 0);
      animation: glitch-b 2.9s infinite linear alternate;
    }
    [data-skin='web3'] .glitch {
      text-shadow: none;
    }

    /* marquee (retro) */
    .s-marquee {
      display: block;
      visibility: hidden; /* reserves its height under every skin */
      width: 100%;
      overflow: hidden;
      border-block: var(--st-bw) solid var(--st-line);
      padding: 0.35rem 0;
      background: #000;
    }
    [data-skin='retro'] .s-marquee {
      visibility: visible;
    }
    .s-marquee span {
      display: inline-block;
      white-space: nowrap;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      color: #4be08a;
      animation: scroll-x 16s linear infinite;
    }
    .s-counter.big {
      display: none;
      font-size: 0.95rem;
      color: var(--st-ink);
    }
    [data-skin='retro'] .s-counter.big {
      display: block;
    }

    .stage-hint {
      margin-top: 1.6rem;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--st-muted); /* reads against the page skin, not cream */
      text-align: center;
    }

    /* ---------- keyframes ---------- */
    @keyframes morph {
      50% {
        border-radius: 60% 40% 33% 67% / 55% 62% 38% 45%;
        transform: translate(6%, 8%) scale(1.12);
      }
    }
    @keyframes tron {
      to {
        background-position:
          0 42px,
          0 42px;
      }
    }
    @keyframes rise {
      to {
        transform: translateY(-46vh);
        opacity: 0;
      }
    }
    @keyframes wobble {
      15% {
        transform: rotate(-4deg) scale(1.04);
      }
      45% {
        transform: rotate(3deg) scale(1.02);
      }
      75% {
        transform: rotate(-2deg);
      }
    }
    @keyframes glowpulse {
      50% {
        box-shadow:
          0 0 34px var(--st-accent),
          inset 0 0 18px color-mix(in srgb, var(--st-accent) 45%, transparent);
      }
    }
    @keyframes flicker {
      50% {
        opacity: 0.72;
      }
    }
    @keyframes scroll-x {
      to {
        transform: translateX(-100%);
      }
    }
    @keyframes glitch-a {
      0%,
      100% {
        transform: translate(0);
      }
      40% {
        transform: translate(-3px, -1px);
      }
      60% {
        transform: translate(2px, 1px);
      }
    }
    @keyframes glitch-b {
      0%,
      100% {
        transform: translate(0);
      }
      35% {
        transform: translate(3px, 1px);
      }
      65% {
        transform: translate(-2px, -1px);
      }
    }

    /* ---------- bonus techniques (tilt + konami) ---------- */
    .extra-sec {
      max-width: 1120px;
      margin-inline: auto;
      padding: clamp(2.5rem, 7vh, 4.5rem) 6vw;
    }
    .extra-inner {
      max-width: 640px;
    }
    .extra-inner h2 {
      font-family: var(--font-quiet);
      font-size: clamp(1.7rem, 3.6vw, 2.5rem);
      margin-bottom: 0.7rem;
      color: var(--st-ink);
    }
    .extra-inner > p {
      color: var(--st-muted);
      font-size: 1.05rem;
      line-height: 1.6;
      max-width: 52ch;
      margin-bottom: 1.4rem;
    }
    .extra-inner kbd {
      font-family: var(--font-mono);
      font-size: 0.82em;
      padding: 0.05em 0.3em;
      margin: 0 0.05em;
      border: 1px solid var(--st-line);
      border-radius: 4px;
      background: var(--st-panel);
      color: var(--st-ink);
    }
    .tilt-stage {
      perspective: 600px;
      margin-bottom: 1.6rem;
    }
    .tilt-card {
      width: 190px;
      height: 130px;
      display: grid;
      place-items: center;
      font-family: var(--st-head);
      font-size: 1.1rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--st-btn-ink);
      background: var(--st-accent);
      border-radius: calc(var(--st-radius) * 0.6);
      box-shadow: var(--st-shadow);
      transition: transform 0.25s ease;
      transform-style: preserve-3d;
      cursor: grab;
    }
    .konami-pad {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 1.6rem;
    }
    .konami-pad button {
      width: 2.4rem;
      height: 2.4rem;
      font-family: var(--font-mono);
      font-size: 1rem;
      border: 1px solid var(--st-line);
      border-radius: 6px;
      background: var(--st-panel);
      color: var(--st-ink);
      cursor: pointer;
      transition:
        transform 0.1s ease,
        background 0.2s ease;
    }
    .konami-pad button:active {
      transform: scale(0.9);
      background: var(--st-accent);
      color: var(--st-btn-ink);
    }

    /* ---------- outro (site chrome, not a skin) ---------- */
    .st-outro {
      background: var(--ink);
      color: var(--paper);
      padding: 12vh 8vw;
      margin-top: 2rem;
    }
    .outro-kicker {
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.85rem;
      opacity: 0.7;
      margin-bottom: 1rem;
    }
    .outro-line {
      font-family: var(--font-loud);
      font-size: clamp(2.2rem, 7vw, 5.5rem);
      text-transform: uppercase;
      line-height: 1;
      max-width: 20ch;
      margin-bottom: 2rem;
    }
    .outro-line em {
      font-family: var(--font-quiet);
      font-style: italic;
      text-transform: none;
      color: #ff8fbf;
    }
    .outro-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .btn {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      text-decoration: none;
      padding: 0.85rem 1.4rem;
      border-radius: 4px;
    }
    .btn.solid {
      background: var(--paper);
      color: var(--ink);
    }
    .btn.ghost {
      border: 1px solid rgba(255, 255, 255, 0.4);
      color: var(--paper);
    }

    @media (max-width: 760px) {
      .sig-sec {
        grid-template-columns: 1fr;
      }
      .sig-sec.reverse .sig {
        order: 0;
      }
      .skin-btn {
        padding: 0.4rem 0.5rem;
        font-size: 0.66rem;
      }
    }
  </style>
</BaseLayout>
