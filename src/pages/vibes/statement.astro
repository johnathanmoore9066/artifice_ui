---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpecTag from '../../components/SpecTag.astro';
import Hud from '../../components/Hud.astro';
import NextVibe from '../../components/NextVibe.astro';

// The skin-switch options. Each id maps to a [data-skin] token block below.
const skins = [
  { id: 'playful', label: 'Playful' },
  { id: 'brutalist', label: 'Brutalist' },
  { id: 'web3', label: 'Web3' },
  { id: 'retro', label: 'Y2K' },
];

// Deterministic particle field for the web3 skin — index-derived so it's
// stable across SSR/hydration (no Math.random in the render pass).
const particles = Array.from({ length: 14 }, (_, i) => ({
  left: (i * 61 + 7) % 100,
  delay: (i % 7) * 0.55,
  dur: 5 + (i % 5),
  size: 3 + (i % 3),
}));
---

<BaseLayout
  title="The Statement -- [ARTIFICE UI]"
  description="One HTML skeleton, four skins -- playful, brutalist, web3, Y2K. Proof that a 'vibe' is just a stylesheet, not really an engineering problem."
>
  <Hud category="Statement" collapsed />

  <main class="statement" data-skin="playful" data-stmt>
    <nav class="demo-nav">
      <a class="demo-back" href="/vibes">← Vibes</a>
      <div class="skin-switch" role="group" aria-label="Skin">
        {
          skins.map((s, i) => (
            <button
              type="button"
              class="skin-btn"
              data-skin-btn={s.id}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              {s.label}
            </button>
          ))
        }
      </div>
    </nav>

    <!-- 1 · THE LIVE SKELETON (the skin-swap itself) -->
    <section
      class="stage-sec"
      data-feature="The skin-swap"
      data-verdict="essential"
    >
      <div class="stage" data-stage>
        <!-- signature backdrops — each shows only under its own skin -->
        <div class="fx fx-blobs" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div class="fx fx-tron" aria-hidden="true"></div>
        <div class="fx fx-particles" aria-hidden="true">
          {particles.map((p) => (
            <span
              style={`left:${p.left}%;width:${p.size}px;height:${p.size}px;animation-delay:${p.delay}s;animation-duration:${p.dur}s;`}
            />
          ))}
        </div>
        <div class="fx fx-scan" aria-hidden="true"></div>

        <div class="stage-inner">
          <p class="s-tag" data-copy="tag">★ new + delightful</p>
          <h1 class="s-title" data-copy="title">Say hello
with a bounce.</h1>
          <p class="s-sub" data-copy="sub">
            Rounded corners, spring-loaded motion, and a confetti cannon on every
            tap. Serotonin, shipped as a design system.
          </p>
          <div class="s-actions">
            <button class="s-btn" type="button" data-copy="btn">Tap for confetti</button>
            <a class="s-link" href="#" data-copy="link">or just say hi →</a>
          </div>
          <div class="s-cards">
            <article class="s-card"><span data-copy="c0">Springy</span></article>
            <article class="s-card"><span data-copy="c1">Squishy</span></article>
            <article class="s-card"><span data-copy="c2">Confetti</span></article>
          </div>
        </div>

        <div class="stage-foot">
          <div class="s-marquee" aria-hidden="true">
            <span>★ WELCOME TO MY HOMEPAGE ★ SIGN MY GUESTBOOK ★ 56K WARNING ★&nbsp;</span>
            <span>★ WELCOME TO MY HOMEPAGE ★ SIGN MY GUESTBOOK ★ 56K WARNING ★&nbsp;</span>
          </div>
          <p class="s-foot" data-copy="foot">made with love + way too much serotonin</p>
          <p class="s-counter">visitors <span data-counter data-count="88213">086000</span></p>
        </div>
      </div>

      <p class="stage-hint">
        Same markup, same layout -- only the stylesheet changed. Hit the skins
        up top ↑, or just scroll -- the page dresses itself to match each
        section below.
      </p>

      <SpecTag
        feature="The skin-swap"
        verdict="essential"
        note="Most 'vibes' aren't actually different machines -- they're one layout wearing a different stylesheet. Swap a set of theme tokens, and this exact markup turns from a toy into a terminal into a spaceship. That's not really a trick; it's basically how a design system is supposed to be built."
        tech="One HTML skeleton. Each skin is a block of CSS custom properties (color, radius, font, shadow, border-width) on a [data-skin] attribute -- the toggle just changes the attribute, and scrolling into each signature section flips the same attribute for you. Zero layout code is duplicated."
      />
    </section>

    <!-- 2 · PLAYFUL -->
    <section
      class="sig-sec"
      data-feature="Playful: spring & confetti"
      data-verdict="vanity"
    >
      <div class="sig" data-skin="playful">
        <div class="fx fx-blobs" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div class="sig-stage">
          <p class="s-tag">★ wobble on hover</p>
          <p class="s-title sig-h">Delight, on tap.</p>
          <div class="s-cards">
            <article class="s-card"><span>Boing</span></article>
            <article class="s-card"><span>Squish</span></article>
            <article class="s-card"><span>Pop</span></article>
          </div>
          <button class="s-btn" type="button">Throw confetti</button>
        </div>
      </div>
      <div class="sig-copy" data-reveal>
        <h2>Playful</h2>
        <p>
          Spring easing, morphing blobs, wobble-on-hover, confetti. Probably the
          friendliest skin in the set -- and the easiest one to overdo.
        </p>
        <SpecTag
          feature="Confetti & spring"
          verdict="vanity"
          note="Confetti is basically a dopamine hit -- delightful the first time, noise every time after that. Springy motion and wobble sell a warm brand, but the celebration should stay rare -- save it for a real win (a finished signup), not every single click."
          tech="Spring feel is an easing curve; the burst spawns short-lived DOM particles animated with GSAP, and it's skipped entirely under prefers-reduced-motion."
        />
      </div>
    </section>

    <!-- 3 · BRUTALIST -->
    <section
      class="sig-sec reverse"
      data-feature="Brutalist: raw HTML"
      data-verdict="situational"
    >
      <div class="sig" data-skin="brutalist">
        <div class="sig-stage">
          <p class="s-tag">HELLO WORLD</p>
          <p class="s-title sig-h">RAW HTML ENERGY</p>
          <p class="sig-line">
            Unstyled, on purpose. Here is <a href="#" class="s-link">a real 1995 link</a>.
          </p>
          <button class="s-btn" type="button">[ CLICK ]</button>
        </div>
      </div>
      <div class="sig-copy" data-reveal>
        <h2>Brutalist</h2>
        <p>
          System mono, 3px borders, zero radius, snap hovers, and links that
          look like they did back in Netscape. It refuses to be pretty on
          purpose.
        </p>
        <SpecTag
          feature="Brutalist raw HTML"
          verdict="situational"
          note="Hard borders, mono type, and 1995-blue links read as honest and memorable -- perfect for a gallery, a zine, or a dev tool with some attitude. On a mainstream storefront though, the same look just reads as broken, and pushes normal users away. Deploy it on purpose, for an audience that actually gets the joke."
          tech="Pure CSS: 3px solid borders, hard offset box-shadows with no blur, and transition: none for a deliberately un-animated, snappy hover."
        />
      </div>
    </section>

    <!-- 4 · WEB3 / FUTURISTIC -->
    <section
      class="sig-sec"
      data-feature="Web3: aurora, grid & glitch"
      data-verdict="vanity"
    >
      <div class="sig" data-skin="web3">
        <div class="fx fx-blobs" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
        <div class="fx fx-tron" aria-hidden="true"></div>
        <div class="fx fx-particles" aria-hidden="true">
          {particles.map((p) => (
            <span
              style={`left:${p.left}%;width:${p.size}px;height:${p.size}px;animation-delay:${p.delay}s;animation-duration:${p.dur}s;`}
            />
          ))}
        </div>
        <div class="sig-stage">
          <p class="s-tag">◆ 0x…c0ffee</p>
          <p class="s-title sig-h glitch" data-text="CONNECT.">CONNECT.</p>
          <button class="s-btn glow" type="button">Connect Wallet</button>
        </div>
      </div>
      <div class="sig-copy" data-reveal>
        <h2>Web3 / Futuristic</h2>
        <p>
          Dark canvas, aurora haze, a Tron floor, drifting particles, glitching
          type, and a button that really wants your wallet.
        </p>
        <SpecTag
          feature="Aurora, Tron grid & glow"
          verdict="vanity"
          note="Neon glow signals 'the future' -- but glow isn't trust. This look launders credibility for projects that often haven't actually earned it, and users have learned to read heavy glow as a yellow flag. Gorgeous, and increasingly kind of a liability."
          tech="The grid is a perspective-transformed repeating-gradient scrolling toward you; the glow is layered box- and text-shadow; particles are a few CSS-animated dots; the glitch is two clipped pseudo-copies of the text. All motion is gated behind reduced-motion."
        />
      </div>
    </section>

    <!-- 5 · RETRO / Y2K -->
    <section
      class="sig-sec reverse"
      data-feature="Retro: chrome, CRT & counter"
      data-verdict="vanity"
    >
      <div class="sig" data-skin="retro">
        <div class="fx fx-scan" aria-hidden="true"></div>
        <div class="sig-stage">
          <p class="s-tag">✧ best viewed in 800×600</p>
          <p class="s-title sig-h chrome">WELCOME!</p>
          <div class="s-marquee" aria-hidden="true">
            <span>★ SIGN MY GUESTBOOK ★ 56K WARNING ★ UNDER CONSTRUCTION ★&nbsp;</span>
            <span>★ SIGN MY GUESTBOOK ★ 56K WARNING ★ UNDER CONSTRUCTION ★&nbsp;</span>
          </div>
          <p class="s-counter big">
            Visitors: <span data-counter data-count="13794">011000</span>
          </p>
          <button class="s-btn" type="button">ENTER SITE »</button>
        </div>
      </div>
      <div class="sig-copy" data-reveal>
        <h2>Retro / Y2K</h2>
        <p>
          Chrome gradients, CRT scanlines, a marquee that will not quit, and a
          visitor counter that's definitely real. Nostalgia, bottled.
        </p>
        <SpecTag
          feature="Chrome, CRT & counter"
          verdict="vanity"
          note="Chrome text, scanlines, a marquee, and a hit counter are pure nostalgia -- a great limited-run gag, or a music/art microsite. As a lasting brand though, it dates in months and fights readability (scanlines over body text are basically eye strain). Fun, with a famously short shelf life."
          tech="Chrome type is a metallic gradient clipped to the glyphs; scanlines are a repeating-linear-gradient overlay; the counter ticks up once when it scrolls into view -- honestly, from where the markup starts."
        />
      </div>
    </section>

    <!-- BONUS · 3D TILT -->
    <section class="extra-sec" data-feature="3D tilt" data-verdict="vanity">
      <div class="extra-inner">
        <h2>Fake depth, real hover.</h2>
        <p>
          Move your cursor across this card. It leans toward you like it's
          floating a few millimetres off the page -- but there's no depth there
          really, just a perspective transform reading your mouse and tilting
          to match. Convincing, and completely cosmetic.
        </p>
        <div class="tilt-stage">
          <div class="tilt-card" data-tilt><span>tilt me</span></div>
        </div>
        <SpecTag
          feature="3D tilt"
          verdict="vanity"
          note="The card that leans toward your cursor sells 'premium' and 'interactive' in one gesture -- and it's basically a parlour trick, easy to overdo into seasickness. One tasteful hero element is charming. A whole grid tilting at once is a headache. Depth's the costume here, not the feature."
          tech="pointermove maps the cursor's position inside the card to a small rotateX / rotateY under CSS perspective, recentred on leave. Skipped on touch and under prefers-reduced-motion."
        />
      </div>
    </section>

    <!-- BONUS · KONAMI -->
    <section class="extra-sec" data-feature="Konami code" data-verdict="vanity">
      <div class="extra-inner">
        <h2>There's a code hidden in here.</h2>
        <p>
          The oldest easter egg on the web:
          <kbd>↑</kbd><kbd>↑</kbd><kbd>↓</kbd><kbd>↓</kbd><kbd>←</kbd><kbd>→</kbd
          ><kbd>←</kbd><kbd>→</kbd><kbd>B</kbd><kbd>A</kbd>. Type it now -- or
          just tap the pad below. Something ridiculous is about to happen, and
          absolutely nothing about the product's going to improve.
        </p>
        <div class="konami-pad" data-konami-pad aria-label="Konami code pad">
          <button type="button" data-k="ArrowUp">↑</button>
          <button type="button" data-k="ArrowUp">↑</button>
          <button type="button" data-k="ArrowDown">↓</button>
          <button type="button" data-k="ArrowDown">↓</button>
          <button type="button" data-k="ArrowLeft">←</button>
          <button type="button" data-k="ArrowRight">→</button>
          <button type="button" data-k="ArrowLeft">←</button>
          <button type="button" data-k="ArrowRight">→</button>
          <button type="button" data-k="b">B</button>
          <button type="button" data-k="a">A</button>
        </div>
        <SpecTag
          feature="Konami code"
          verdict="vanity"
          note="A secret handshake for the people who already know to look for it. It builds zero trust, converts no one, and delights nobody who isn't already delighted to be here -- which is kind of the point. Pure joy, pure vanity, and worth it precisely because it costs so little to hide."
          tech="A keydown listener matches the last ten keys against the sequence; a hit fires the same confetti burst as the playful skin. The on-screen pad feeds the same matcher so touch users get in too."
        />
      </div>
    </section>

    <!-- OUTRO -->
    <section class="st-outro" data-hud-hide>
      <p class="outro-kicker">That's the Statement.</p>
      <h2 class="outro-line">
        Same skeleton -- the <em>vibe</em> is just a stylesheet.
      </h2>
      <div class="outro-actions">
        <a class="btn ghost" href="/vibes">← Back to the vibes</a>
        <a class="btn solid" href="/">Get this for my brand →</a>
      </div>
      <NextVibe href="/vibes/editorial" name="The Editorial" />
    </section>
  </main>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const statement = document.querySelector<HTMLElement>('[data-stmt]')!;
    const stage = document.querySelector<HTMLElement>('[data-stage]')!;
    const skinBtns =
      document.querySelectorAll<HTMLButtonElement>('[data-skin-btn]');

    /**
     * Per-skin copy for the live skeleton. Only the text (and the [data-skin]
     * attribute) changes between skins — the markup and layout are identical.
     */
    const copy: Record<string, Record<string, string>> = {
      playful: {
        tag: '★ new + delightful',
        title: 'Say hello\nwith a bounce.',
        sub: 'Rounded corners, spring-loaded motion, and a confetti cannon on every tap. Serotonin, shipped as a design system.',
        btn: 'Tap for confetti',
        link: 'or just say hi →',
        c0: 'Springy',
        c1: 'Squishy',
        c2: 'Confetti',
        foot: 'made with love + way too much serotonin',
      },
      brutalist: {
        tag: 'NO STYLE = STYLE',
        title: 'THIS IS\nBRUTALISM.',
        sub: 'System mono. 3px borders. Zero radius. Links that look like 1995 because they are. It refuses to be pretty — that is the entire point.',
        btn: '[ SUBMIT ]',
        link: 'read the manifesto',
        c0: 'CONCRETE',
        c1: 'MONO',
        c2: 'NO RADIUS',
        foot: 'NO COOKIES. NO FRAMEWORKS. NO MERCY.',
      },
      web3: {
        tag: '◆ on-chain · gasless',
        title: 'Enter\nthe grid.',
        sub: 'Aurora haze, a Tron floor, drifting particles, and a button that really wants your wallet. Looks like the future; trusts like a stranger in a dark alley.',
        btn: 'Connect Wallet',
        link: 'read the whitepaper →',
        c0: 'Decentralized',
        c1: 'Immutable',
        c2: 'Vaporware?',
        foot: 'not financial advice · gm · wagmi',
      },
      retro: {
        tag: '✧ best viewed in 800×600',
        title: 'Welcome\nto the Y2K.',
        sub: 'Chrome gradients, CRT scanlines, a marquee that will not quit, and a visitor counter that is definitely real. Nostalgia with a famously short shelf life.',
        btn: 'ENTER SITE »',
        link: 'sign my guestbook',
        c0: 'GuestBook',
        c1: 'Webring',
        c2: 'Under Constr.',
        foot: '© 1999 · best viewed in Netscape Navigator',
      },
    };

    /**
     * Swap the live skeleton to a skin: flip the [data-skin] attribute, rewrite
     * the copy, and sync the toggle's pressed state.
     * @param skin - One of playful | brutalist | web3 | retro.
     * @param fromScroll - True when the scroll-sync triggers below drive the
     *   swap. Scroll-driven swaps skip ScrollTrigger.refresh() (never refresh
     *   from inside a trigger callback) and skip the confetti reward (it's for
     *   CHOOSING playful, not for scrolling past it).
     */
    function setSkin(skin: string, fromScroll = false): void {
      const c = copy[skin];
      if (!c) throw new Error(`Unknown skin "${skin}" — no copy defined.`);
      if (statement.dataset.skin === skin) return; // already wearing it
      statement.dataset.skin = skin;
      for (const key in c) {
        const el = stage.querySelector<HTMLElement>(`[data-copy="${key}"]`);
        if (el) el.textContent = c[key];
      }
      skinBtns.forEach((b) =>
        b.setAttribute('aria-pressed', String(b.dataset.skinBtn === skin)),
      );
      if (!fromScroll) {
        // Copy/font swaps can nudge heights a little; keep triggered anims
        // honest after a manual swap. (Safe here: clicks never run inside a
        // ScrollTrigger callback.)
        ScrollTrigger.refresh();
        // A little reward when you land on Playful.
        if (skin === 'playful') {
          const active = statement.querySelector<HTMLElement>(
            '[data-skin-btn="playful"]',
          );
          if (active) burstFrom(active);
        }
      }
    }

    skinBtns.forEach((b) =>
      b.addEventListener('click', () => setSkin(b.dataset.skinBtn!)),
    );

    // --- Scroll-synced skin: each signature section dresses the whole page to
    //     match what it's showing off, and the toggle up top follows along. A
    //     manual click still wins until the next section boundary re-syncs.
    //     Created even under prefers-reduced-motion: this is a discrete state
    //     change, not motion (the global reduced-motion CSS makes it instant),
    //     and skipping it would reintroduce the page-vs-panel contrast clash. ---
    document.querySelectorAll<HTMLElement>('.sig-sec').forEach((section) => {
      const skin =
        section.querySelector<HTMLElement>('.sig[data-skin]')?.dataset.skin;
      if (!skin) return;
      ScrollTrigger.create({
        trigger: section,
        start: 'top 55%',
        end: 'bottom 55%',
        onEnter: () => setSkin(skin, true),
        onEnterBack: () => setSkin(skin, true),
      });
    });

    /**
     * Fire a confetti burst centered on an element's bounding box.
     * @param el - The element to burst from.
     */
    function burstFrom(el: Element): void {
      const r = el.getBoundingClientRect();
      confettiBurst(r.left + r.width / 2, r.top + r.height / 2);
    }

    /**
     * Spawn a one-shot confetti burst at viewport coordinates. Particles are
     * fully inline-styled and animated with GSAP, then removed on completion.
     * No-op under prefers-reduced-motion.
     * @param x - Viewport x in pixels.
     * @param y - Viewport y in pixels.
     */
    function confettiBurst(x: number, y: number): void {
      if (reduce) return;
      const colors = ['#ff4fa3', '#8a5cff', '#ffd23b', '#3bd0ff', '#4be08a'];
      for (let i = 0; i < 84; i++) {
        const p = document.createElement('span');
        p.style.cssText = `position:fixed;left:${x}px;top:${y}px;width:8px;height:13px;background:${colors[i % colors.length]};border-radius:2px;pointer-events:none;z-index:90;will-change:transform;`;
        document.body.appendChild(p);
        const angle = Math.random() * Math.PI * 2;
        const dist = 110 + Math.random() * 240;
        gsap.to(p, {
          x: Math.cos(angle) * dist,
          y: Math.sin(angle) * dist + 260,
          rotation: Math.random() * 720 - 360,
          opacity: 0,
          duration: 1 + Math.random() * 0.9,
          ease: 'power3.out',
          onComplete: () => p.remove(),
        });
      }
    }

    // Any button rendered in a "playful" skin context throws confetti; the rest
    // are demo-only and simply swallow their click.
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.s-btn');
      if (!btn) return;
      e.preventDefault();
      const skin = btn.closest<HTMLElement>('[data-skin]')?.dataset.skin;
      if (skin === 'playful') burstFrom(btn);
    });

    // Demo-only links shouldn't navigate to "#".
    document.querySelectorAll('.s-link').forEach((a) =>
      a.addEventListener('click', (e) => e.preventDefault()),
    );

    // --- Visitor counters: tick up once when scrolled into view ---
    const pad = (n: number) => String(n).padStart(6, '0');
    gsap.utils.toArray<HTMLElement>('[data-counter]').forEach((el) => {
      const target = parseInt(el.dataset.count ?? '0', 10);
      if (reduce) {
        el.textContent = pad(target);
        return;
      }
      const obj = { v: Math.max(0, target - 2200) };
      ScrollTrigger.create({
        trigger: el,
        start: 'top 92%',
        once: true,
        onEnter: () =>
          gsap.to(obj, {
            v: target,
            duration: 2,
            ease: 'power2.out',
            onUpdate: () => (el.textContent = pad(Math.round(obj.v))),
          }),
      });
    });

    // --- Scroll reveals (copy columns + outro) ---
    if (!reduce) {
      gsap.utils.toArray<HTMLElement>('[data-reveal]').forEach((el) => {
        gsap.from(el, {
          scrollTrigger: { trigger: el, start: 'top 88%' },
          y: 28,
          opacity: 0,
          duration: 0.7,
          ease: 'power3.out',
        });
      });
    }

    // --- 3D tilt (vanity): lean the card toward the pointer. Desktop only. ---
    if (!reduce && window.matchMedia('(pointer: fine)').matches) {
      const MAX = 12;
      document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
        card.addEventListener('pointermove', (e) => {
          const r = card.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width - 0.5;
          const py = (e.clientY - r.top) / r.height - 0.5;
          card.style.transform = `perspective(600px) rotateY(${px * MAX}deg) rotateX(${-py * MAX}deg)`;
        });
        card.addEventListener('pointerleave', () => {
          card.style.transform = '';
        });
      });
    }

    // --- Konami code (vanity): the sequence throws a confetti storm ---
    const KONAMI = [
      'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
      'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a',
    ];
    let konamiBuf: string[] = [];
    const konamiStorm = () => {
      const w = window.innerWidth;
      const h = window.innerHeight;
      for (let i = 0; i < 6; i++) {
        window.setTimeout(
          () => confettiBurst(Math.random() * w, Math.random() * h * 0.6),
          i * 140,
        );
      }
    };
    const konamiPush = (key: string) => {
      konamiBuf.push(key.length === 1 ? key.toLowerCase() : key);
      if (konamiBuf.length > KONAMI.length) konamiBuf.shift();
      if (
        konamiBuf.length === KONAMI.length &&
        KONAMI.every((k, i) => konamiBuf[i] === k)
      ) {
        konamiBuf = [];
        konamiStorm();
      }
    };
    window.addEventListener('keydown', (e) => konamiPush(e.key));
    document
      .querySelectorAll<HTMLButtonElement>('[data-konami-pad] button')
      .forEach((b) => b.addEventListener('click', () => konamiPush(b.dataset.k ?? '')));
    // No initial setSkin call: the SSR markup already ships the playful skin,
    // copy, and pressed state. (Calling it used to confetti-bomb first paint.)
  </script>

  <style>
    /* ============================================================
       THE STATEMENT — one skeleton, four skins.
       Every skin is just a block of custom properties on [data-skin].
       The same tokens drive the live stage (toggle) and each locked
       signature panel, so no skin styling is written twice.
       ============================================================ */

    /* ---------- skin token sets ---------- */
    [data-skin] {
      --st-bg: #fdeffb;
      --st-panel: #ffffff;
      --st-ink: #2a1633;
      --st-muted: #8a6b95;
      --st-accent: #ff4fa3;
      --st-accent2: #8a5cff;
      --st-line: #f3cfe6;
      --st-btn-ink: #ffffff;
      --st-radius: 22px;
      --st-bw: 1px;
      --st-head: var(--font-body);
      --st-body: var(--font-body);
      --st-shadow: 0 20px 44px -20px rgba(255, 79, 163, 0.55);
    }
    [data-skin='brutalist'] {
      --st-bg: #ffffff;
      --st-panel: #ffffff;
      --st-ink: #000000;
      --st-muted: #2b2b2b;
      --st-accent: #1a1aff;
      --st-accent2: #ec1c24;
      --st-line: #000000;
      --st-btn-ink: #ffffff;
      --st-radius: 0px;
      --st-bw: 3px;
      --st-head: var(--font-mono);
      --st-body: var(--font-mono);
      --st-shadow: 6px 6px 0 #000000;
    }
    [data-skin='web3'] {
      --st-bg: #05060d;
      --st-panel: rgba(18, 22, 44, 0.55);
      --st-ink: #eafcff;
      --st-muted: #8ea3cf;
      --st-accent: #23e5ff;
      --st-accent2: #b14cff;
      --st-line: rgba(120, 180, 255, 0.24);
      --st-btn-ink: #04121a;
      --st-radius: 14px;
      --st-bw: 1px;
