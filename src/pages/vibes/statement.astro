      --st-bw: 2px;
      --st-head: var(--font-loud);
      --st-body: var(--font-body);
      --st-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.14);
    }

    .statement {
      position: relative;
      min-height: 100vh;
      background: var(--st-bg);
      color: var(--st-ink);
      font-family: var(--st-body);
      transition:
        background-color 0.55s ease,
        color 0.55s ease;
    }

    /* ---------- top nav + skin switch ---------- */
    .demo-nav {
      position: fixed;
      inset: 0 0 auto 0;
      z-index: 60;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      padding: 0.9rem 1.4rem;
    }
    .demo-back {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      text-decoration: none;
      color: var(--st-ink);
      background: color-mix(in srgb, var(--st-bg) 80%, transparent);
      padding: 0.4rem 0.7rem;
      border-radius: 6px;
      border: 1px solid var(--st-line);
      backdrop-filter: blur(6px);
    }
    .skin-switch {
      display: flex;
      gap: 0.2rem;
      padding: 0.25rem;
      background: color-mix(in srgb, var(--st-bg) 82%, transparent);
      border: 1px solid var(--st-line);
      border-radius: 999px;
      backdrop-filter: blur(8px);
    }
    .skin-btn {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      padding: 0.4rem 0.7rem;
      border: none;
      border-radius: 999px;
      background: transparent;
      color: var(--st-ink);
      cursor: pointer;
      transition:
