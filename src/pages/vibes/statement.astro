      --st-body: var(--font-body);
      --st-shadow: 0 0 44px rgba(35, 229, 255, 0.32);
    }
    [data-skin='retro'] {
      --st-bg: #12123a;
      --st-panel: #1b1b57;
      --st-ink: #e8ecff;
