    /* inline newsletter */
    .newsletter {
      margin: 2rem 0;
      padding: 1.6rem;
      background: var(--ink);
      color: var(--paper);
      border-radius: 8px;
    }
    .newsletter-kicker {
      font-family: var(--font-mono) !important;
      font-size: 0.72rem !important;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      opacity: 0.7;
      margin-bottom: 0.3rem !important;
      line-height: 1.3 !important;
