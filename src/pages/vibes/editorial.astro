      margin-bottom: 0 !important;
      line-height: 1.5 !important;
    }

    .closing {
      color: var(--ink-soft);
    }

    /* metered paywall (⚠ manipulative) — a full-height wall that rises in */
    .paywall-content {
      max-height: 100rem;
      transition: max-height 0.7s ease;
    }
    .paywall-sec.is-locked .paywall-content {
      max-height: 8rem;
      overflow: hidden;
      -webkit-mask-image: linear-gradient(to bottom, #000 20%, transparent);
      mask-image: linear-gradient(to bottom, #000 20%, transparent);
    }
    .paywall-gate {
      display: none;
    }
    .paywall-sec.is-locked .paywall-gate {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: grid;
      place-items: center;
      min-height: 100vh;
      padding: 3rem 1.2rem;
      background: var(--paper);
      opacity: 0;
      visibility: hidden;
      transform: translateY(60px);
      transition:
        opacity 0.6s ease,
        transform 0.8s cubic-bezier(0.4, 0, 0.1, 1),
        visibility 0.6s ease;
    }
    .paywall-sec.is-locked.is-revealed .paywall-gate {
      opacity: 1;
      visibility: visible;
      transform: none;
    }
    .gate-card {
      max-width: 38rem;
      width: 100%;
      margin: 0 auto;
      padding: 2.6rem 2.2rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 14px;
      box-shadow: 0 40px 90px -50px rgba(0, 0, 0, 0.55);
      text-align: center;
    }
    .gate-lock {
      width: 42px;
      height: 42px;
      margin: 0 auto 1.1rem;
      color: var(--ed-accent);
    }
    .gate-eyebrow {
      font-family: var(--font-mono) !important;
      font-size: 0.74rem !important;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--v-manipulative);
      margin-bottom: 0.7rem !important;
      line-height: 1.4 !important;
    }
    .gate-card h3 {
      font-family: var(--font-quiet);
      font-weight: 600;
      font-size: clamp(1.7rem, 4vw, 2.4rem);
      margin: 0 0 0.8rem;
    }
    .gate-lede {
      font-family: var(--font-quiet) !important;
      font-size: 1.08rem !important;
      color: var(--ink-soft);
      margin: 0 auto 1.6rem !important;
      line-height: 1.6 !important;
      max-width: 40ch;
    }
    .gate-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 0.9rem;
    }
    .gate-unlock {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      padding: 0.85rem 1.5rem;
      border: none;
      border-radius: 8px;
      background: var(--ink);
      color: var(--paper);
      cursor: pointer;
    }
    .gate-price {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--ink-soft);
    }
    .gate-fine {
      font-family: var(--font-mono) !important;
      font-size: 0.72rem !important;
      color: var(--ink-soft);
      opacity: 0.7;
      margin: 1.4rem auto 0 !important;
      max-width: 42ch;
      line-height: 1.5 !important;
    }

    /* read next (essential) */
    .rn-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.9rem;
      margin: 1.4rem 0 0;
    }
    @media (min-width: 620px) {
      .rn-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .rn-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.1rem 1.2rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 8px;
      text-decoration: none;
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease,
        border-color 0.2s ease;
    }
    .rn-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 34px -22px rgba(0, 0, 0, 0.4);
      border-color: color-mix(in srgb, var(--ed-accent) 40%, var(--line));
    }
    .rn-cat {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--ed-accent);
