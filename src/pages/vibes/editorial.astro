    .rn-meta {
      margin-top: auto;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--ink-soft);
    }

    /* spec tags sit a little apart from the prose */
    .ed-sec :global(.spec-tag),
    .piece-head :global(.spec-tag) {
      margin-top: 1.6rem;
    }

    /* gentle heading reveal */
    .reveal-h {
      opacity: 0;
      transform: translateY(10px);
      transition:
        opacity 0.6s ease,
        transform 0.6s ease;
    }
    .reveal-h.is-in {
      opacity: 1;
      transform: none;
    }

    /* sticky reservation bar */
    .reserve-bar {
      position: fixed;
      left: 50%;
      bottom: 1.2rem;
      transform: translate(-50%, 160%);
      z-index: 55;
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 0.7rem 0.8rem 0.7rem 1.3rem;
      background: var(--ed-accent);
      color: #fff;
      border-radius: 999px;
      box-shadow: 0 16px 40px -16px rgba(0, 0, 0, 0.5);
      transition: transform 0.45s cubic-bezier(0.4, 0, 0.1, 1);
    }
    .reserve-bar.is-visible {
      transform: translate(-50%, 0);
    }
    .reserve-text {
      font-family: var(--font-quiet);
      font-style: italic;
      font-size: 0.98rem;
    }
    .reserve-btn {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      padding: 0.5rem 1rem;
      border: none;
      border-radius: 999px;
      background: #fff;
      color: var(--ed-accent);
      cursor: pointer;
    }

    /* outro (site chrome) */
    .ed-outro {
      background: var(--ink);
      color: var(--paper);
      padding: 12vh 8vw;
      margin-top: 3rem;
